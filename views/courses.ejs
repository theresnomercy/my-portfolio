<%- include('partials/head') %>
<%- include('partials/navbar', { page }) %>

<main class="page-root">
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h1 class="section-title">Courses &amp; Certificates</h1>
        <p class="section-subtitle">
          A timeline of structured learning — combining university work with intentional,
          self-directed courses.
        </p>
      </div>
      <div class="timeline">
        <% courses.forEach(function(item) { %>
          <div class="timeline-item">
            <div class="timeline-year"><%= item.dateLabel %></div>
            <div class="timeline-card">
              <h2 class="timeline-title"><%= item.title %></h2>
              <p class="timeline-body"><%= item.type %> — <%= item.provider %></p>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>

